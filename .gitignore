# Python
__pycache__/
*.py[cod]
*.so
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/

# Large model artifacts (do not commit)
vectors/*.pth
vectors/*.bin
*.safetensors
*.ckpt

# Large per-sample evaluation artifacts; retain curated Markdown summaries.
results/**/*.json
results/*.json
results/**/*.tmp
# Small, content-addressed answer audits are reproducibility metadata.
!results/answer_audits/
!results/answer_audits/*.json
*.tmp

# Credentials and machine-specific configuration
.env
.env.*
!.env.example
*.pem
*.key
.vscode/
.idea/

# Upstream research snapshots without an explicit redistribution license.
# Keep local copies for reading; use reference/ACTIVATION_ENGINEERING_2024_INDEX.md
# for canonical source URLs and pinned provenance.
reference/ACT-main/
reference/kts-source/

# OS files
.DS_Store
Thumbs.db
